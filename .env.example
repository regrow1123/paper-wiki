# Copy to .env and adjust as needed

# llama-server binary path (built from https://github.com/ggml-org/llama.cpp)
LLAMA_SERVER_BIN=/home/sund4y/llama.cpp/build/bin/llama-server

# GGUF model file paths (relative to project root or absolute)
EMBED_MODEL_PATH=models/Qwen3-Embedding-0.6B-Q8_0.gguf
RERANK_MODEL_PATH=models/Qwen3-Reranker-0.6B-Q8_0.gguf

# llama-server bind addresses
EMBED_HOST=127.0.0.1
EMBED_PORT=8081
RERANK_HOST=127.0.0.1
RERANK_PORT=8082

# Force CPU (set to 0 to run fully on CPU even if CUDA build is available)
LLAMA_NGL=0

# LlamaIndex / Chroma
CHROMA_DIR=storage/chroma
CHROMA_COLLECTION=paper_wiki
RAW_DIR=raw
WIKI_DIR=wiki

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Retrieval
TOP_K_RETRIEVE=30
TOP_K_RERANK=10

# HTTP timeouts (seconds)
EMBED_TIMEOUT=120
RERANK_TIMEOUT=120
